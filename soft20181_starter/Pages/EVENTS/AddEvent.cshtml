@page "/AddEvent"
@model soft20181_starter.Pages.AddEventModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Create Event";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="contact.css">
    <link rel="stylesheet" type="text/css" href="contact.css" media="all" />
    <script src="https://kit.fontawesome.com/ca93055bb3.js" crossorigin="anonymous"></script>
</head>
<body>
    <header>
        <ul>
            <li><a href="SignUp" class="no-change">Sign Up</a></li>
            <li><a href="Login" class="no-change">Log In</a></li>
            <div class="no-change">
                <div class="Logo">
                    <label>Eventbox</label>
                </div>
            </div>
        </ul>
        <div class="topnav" id="myTopnav">
            <i class="fa-solid fa-sun" style="font-size:35px; padding-right: 5px;" onclick="switchToLightMode()"></i>
            <i class="fa-solid fa-moon" style="font-size:35px; padding:5px;" onclick="switchToDarkMode()"></i>
            <i class="fa-solid fa-plus" style="font-size:35px; padding: 5px;" onclick="increaseFontsize()"></i>
            <i class="fa-solid fa-minus" style="font-size: 35px; padding: 5px;" onclick="increaseFontsize()"></i>
            <a href="Index">Home</a>
            <a href="AddEvent" class="active">CreateEvent</a>
            <a href="Events">Events</a>
            <a href="EventDetail">Details</a>
            <a href="Contact">Contact</a>
            <a href="javascript:void(0);" class="icon" onclick="myFunction()">
                <i class="fa fa-bars"></i>
            </a>
        </div>
    </header>

    <form method="post">
    <div class="form-group">
        <label for="Title">Title:</label>
        <input type="text" id="Title" class="form-control" asp-for="theEvent.Title" />
        <span asp-validation-for="theEvent.Title" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="EventDescription">Description:</label>
        <input type="text" id="EventDescription" class="form-control" asp-for="theEvent.EventDescription" />
        <span asp-validation-for="theEvent.EventDescription" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="CoverPhoto">Cover Photo:</label>
        <input type="text" id="CoverPhoto" class="form-control" asp-for="theEvent.CoverPhoto" />
        <span asp-validation-for="theEvent.CoverPhoto" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="EventStartDate">Start Date:</label>
        <input type="date" id="EventStartDate" class="form-control" asp-for="theEvent.EventStartDate" asp-format="{0:yyyy-MM-dd}" />
        <span asp-validation-for="theEvent.EventStartDate" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="EventStartTime">Start Time:</label>
        <input type="time" id="EventStartTime" class="form-control" asp-for="theEvent.EventStartTime" asp-format="{0:HH:mm}" step="60" />
        <span asp-validation-for="theEvent.EventStartTime" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="EventEndTime">End Time:</label>
        <input type="time" id="EventEndTime" class="form-control" asp-for="theEvent.EventEndTime" asp-format="{0:HH:mm}" step="60" />
        <span asp-validation-for="theEvent.EventEndTime" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="ELocation">Location:</label>
        <input type="text" id="ELocation" class="form-control" asp-for="theEvent.ELocation" />
        <span asp-validation-for="theEvent.ELocation" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="Price">Price:</label>
        <input type="number" id="Price" class="form-control" asp-for="theEvent.Price" />
        <span asp-validation-for="theEvent.Price" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="TicketsAvailable">Ticket Quantity:</label>
        <input type="number" id="TicketsAvailable" class="form-control" asp-for="theEvent.TicketsAvailable" />
        <span asp-validation-for="theEvent.TicketsAvailable" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create Event</button>
</form>
</body>
</html>


    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

